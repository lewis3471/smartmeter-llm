# Kopie nach .env und Werte eintragen
GEMINI_API_KEY=
# Mehrere Keys mit Komma anhaengen: Rotation bei 429/503
GEMINI_API_KEYS=
GEMINI_MODELS=gemini-flash-lite-latest,gemini-flash-latest,gemini-2.5-flash-lite,gemini-2.5-flash

# Lesemodus: gemini | local (nur OCR) | hybrid (OCR + Gemini-Fallback/Check)
READER_MODE=hybrid
OCR_MIN_CONF=0.85         # darunter fragt hybrid Gemini
CROSS_CHECK_EVERY=300
SAVE_SAMPLES_DIR=/app/samples  # Trainingsdaten + Fehlerbilder (leer = aus)

# ESPHome Native API der Cam (bevorzugt, steuert auch die Blitz-LED)
ESPHOME_HOST=192.168.178.58
ESPHOME_API_KEY=
LED_BRIGHTNESS=0.45       # 30% ist die OCR-Untergrenze, 45% = sicher
CAM_FRAMES=6              # Warm-up-Frames; bei aec_mode:manual auf 1 setzen
GEMINI_PROMPT=Foto eines EasyMeter-Stromzaehler-LCDs mit zwei Zeilen. Zeile 1 = Zaehlerstand in kWh: IMMER exakt 6 Ziffern, ggf. mit fuehrender Null (z.B. 035774) — gib ALLE 6 Ziffern an, lass niemals die letzte Ziffer weg. Zeile 2 = aktuelle Leistung in W (1-5 Ziffern), KANN NEGATIV sein: pruefe genau, ob links ein Minuszeichen steht. Sonderfaelle: LCD-Segmenttest (beide Zeilen zeigen nur 8er) -> {"kwh":888888,"w":888888}; Display dunkel oder unlesbar -> {"kwh":0,"w":0}. Antworte NUR mit JSON: {"kwh":int,"w":int}

CAM_SNAPSHOT_URL=http://192.168.178.58:8080/snapshot

OPENDTU_URL=http://192.168.178.42
OPENDTU_USER=admin
OPENDTU_PASS=
INVERTER_SERIAL=

MQTT_HOST=
MQTT_PORT=1883
MQTT_USER=
MQTT_PASS=
MQTT_TOPIC_PREFIX=smartmeter

# --- Regelung (Nulleinspeisung) ---
INTERVAL_S=0
TARGET_GRID_W=-50
DEADBAND_W=15
MIN_LIMIT_W=50
MAX_LIMIT_W=2000          # max. AC-Leistung (HMS-2000-4T: 2000 W)
FAILSAFE_LIMIT_W=1999      # nach 3 Fehl-Lesungen in Folge
MAX_JUMP_W=5000           # Plausibilitaet: max. Sprung zwischen Lesungen

# Kamera-Modus: flash (LED pro Zyklus an/aus) | continuous (LED dauerhaft an, 1s-Takt moeglich)
CAM_MODE=continuous
CONTROL_EVERY=1
FAILSAFE_AFTER=10          # Failsafe erst nach N Fehl-Zyklen
GEMINI_COOLDOWN_S=30      # min. Abstand zwischen Gemini-Fallback-Calls

# --- PI-Regler (Regler v2) ---
LATENCY_S=8               # Totzeit — gilt nur fuer Runter-Korrekturen

# Auto-Training (Stunde 0-23, -1 = aus); Training erst nach Label-Audit
AUTO_TRAIN_HOUR=-1

LOG_LEVEL=all              # all | error | none

# --- Akku-Waechter (Victron an Strings; leer = aus) ---
BATT_STRINGS=          # z.B. 1,4 — Inverter-Eingaenge mit Akku
BATT_LOW_V=36          # darunter: Entnahme aus Akku-Strings stoppen
BATT_HIGH_V=38         # ab hier: wieder freigeben (Hysterese)
BATT_MAX_DRAIN_W=10    # tolerierte Rest-Entnahme im Hold
